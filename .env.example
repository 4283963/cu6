SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=privacy_relay
MYSQL_CHARSET=utf8mb4
MYSQL_MAX_OPEN_CONNS=100
MYSQL_MAX_IDLE_CONNS=20
MYSQL_CONN_MAX_LIFETIME=1h

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

RELAY_IDEMPOTENT_TTL=24h
RELAY_MAX_RETRY_COUNT=5
RELAY_BASE_RETRY_BACKOFF=1s
RELAY_MAX_RETRY_BACKOFF=60s
RELAY_REPLAY_TTL=5m
RELAY_STATE_LOCK_TTL=10s

SECURITY_TIMESTAMP_TOLERANCE=5m
SECURITY_API_SECRET=please-change-this-secret-in-production
